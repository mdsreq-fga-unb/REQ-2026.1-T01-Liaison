# ───────────────────────────────────────────
# 1. Local network IP (mobile-first)
# ───────────────────────────────────────────
# Expo Go (no celular) precisa alcançar o backend via IP da rede local.
# Descubra o seu IP executando um destes comandos no terminal:
#
#   macOS:    ipconfig getifaddr en0
#   Linux:    hostname -I
#   Windows:  ipconfig  (procure "IPv4 Address")
#
# Troque o valor abaixo pelo IP encontrado:
LOCAL_IP=<YOUR_LOCAL_IP>

# ───────────────────────────────────────────
# 2. Django
# ───────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# ALLOWED_HOSTS é construído automaticamente a partir de LOCAL_IP.
# Se precisar adicionar hosts extras (ex: domínio de staging), descomente:
# ALLOWED_HOSTS_EXTRA=staging.liaison.app

# ───────────────────────────────────────────
# 3. Database
# ───────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/liaison

# ───────────────────────────────────────────
# 4. CORS
# ───────────────────────────────────────────
# CORS_ALLOWED_ORIGINS é construído automaticamente a partir de LOCAL_IP.
# Se precisar adicionar origens extras, descomente:
# CORS_ALLOWED_ORIGINS_EXTRA=https://admin.liaison.app
