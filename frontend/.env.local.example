# Copy this file to: .env.local
#
# The same IP you set as LOCAL_IP in the root .env file.
# Find your IP: ipconfig getifaddr en0 (macOS) | hostname -I (Linux)
#
# Only needed when testing with Expo Go on a physical device.
# Leave unset for web/emulator (defaults to localhost).
EXPO_PUBLIC_API_BASE_URL=http://<YOUR_LOCAL_IP>:8000/api/v1
EXPO_PUBLIC_API_URL=http://<SEU_IP>:8000/api