{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web && node scripts/pwa-postbuild.mjs",
    "test": "NODE_ENV=test jest --watchAll=false",
    "type-check": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "\\.svg$": "<rootDir>/__mocks__/svgMock.tsx",
      "@expo/vector-icons": "<rootDir>/__mocks__/@expo/vector-icons.tsx",
      "react-native-keyboard-aware-scroll-view": "<rootDir>/__mocks__/react-native-keyboard-aware-scroll-view.tsx"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "expo": "~54.0.33",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.0.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "private": true
}
